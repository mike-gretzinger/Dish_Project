                        <item guid="eaa6e2df-6bf9-44fb-b979-fcaf6d57f0b7" action="comment" useFieldsInCommand="false">
                            <command>
                                <body>For SIP reg count grab the count from the middle of the test because something FUNKY is happening with this count at the end of test</body>
                            </command>
                            <nestedSteps>
                                <item guid="821ae5c2-2783-4cad-8fa4-4cf185a59e88" action="comment" useFieldsInCommand="false">
                                    <command>
                                        <body>get middle number</body>
                                    </command>
                                    <nestedSteps>
                                        <item guid="dc5d86e1-d90a-4a03-82d7-ac41227ce46e" action="eval" useFieldsInCommand="false">
                                            <command>
                                                <body>[*results_dict[&apos;Gm|Main&apos;]]</body>
                                            </command>
                                            <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                                        </item>
                                        <item guid="b525971a-4b7b-400c-aad3-e73d3a682c20" action="eval" useFieldsInCommand="false">
                                            <command>
                                                <body>middle_num = int(int([*results_dict[&apos;Gm|Main&apos;]][-2])/2)</body>
                                            </command>
                                            <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                                        </item>
                                        <item guid="d07fce57-73d4-4e9a-83b8-6e3f4b8667ac" action="eval" useFieldsInCommand="false">
                                            <command>
                                                <body>middle_num</body>
                                            </command>
                                            <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                                        </item>
                                    </nestedSteps>
                                    <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                                </item>
                                <item guid="c2c52173-bef2-4e0f-9a36-795963c118a2" action="comment" useFieldsInCommand="false">
                                    <command>
                                        <body>overwrite gm SIP Reg count from end w/ count from middle</body>
                                    </command>
                                    <nestedSteps>
                                        <item guid="cc52ad9f-a21a-4298-b8ef-71537c03e395" action="eval" useFieldsInCommand="false">
                                            <command>
                                                <body>indx = int([i for i, s in enumerate(results_dict[&apos;Gm|Main&apos;][&apos;headers&apos;]) if &apos;SIP Registration Setup Count&apos; in s][0])</body>
                                            </command>
                                            <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                                        </item>
                                        <item guid="f0310a21-f955-408c-a67d-9bc4622850e0" action="eval" useFieldsInCommand="false">
                                            <command>
                                                <body>gm_dict[&apos;SIP Registration Setup Count&apos;] = int(float(results_dict[&apos;Gm|Main&apos;][str(middle_num)][indx]))</body>
                                            </command>
                                            <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                                        </item>
                                    </nestedSteps>
                                    <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                                </item>
                            </nestedSteps>
                            <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                        </item>
                        <item guid="4f3e8736-8494-46ea-8387-14024da988c1" action="comment" useFieldsInCommand="false">
                            <command>
                                <body>Report results</body>
                            </command>
                            <nestedSteps>
                                <item guid="acf7a01c-23f6-4b08-bef4-dff425a5647c" action="comment" useFieldsInCommand="false">
                                    <command>
                                        <body>Output text</body>
                                    </command>
                                    <nestedSteps>
                                        <item guid="1834c1d1-977a-40bd-8dc9-a39c418e6c2d" action="eval" useFieldsInCommand="false">
                                            <command>
                                                <body>total_calls= gm_dict[&apos;SIP Call Successes&apos;]+gm_dict[&apos;SIP Call Failures&apos;]</body>
                                            </command>
                                            <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                                        </item>
                                        <item guid="39825501-45a8-481c-ba77-bbc400b81618" action="if" useFieldsInCommand="false">
                                            <command>
                                                <body>total_calls == 0:</body>
                                            </command>
                                            <nestedSteps>
                                                <item guid="f3dca234-6c7a-4125-9621-30de98e98fbe" action="eval" useFieldsInCommand="false">
                                                    <command>
                                                        <body>pct_good = 0</body>
                                                    </command>
                                                    <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                                                </item>
                                                <item guid="3ea87ce9-d567-4471-b9e8-434f10c0cda7" action="message" useFieldsInCommand="false">
                                                    <command>
                                                        <body>Error:-Registration Failure</body>
                                                    </command>
                                                    <applicationProperties type="com.fnfr.svt.execution.builtin.exec.MessagePropertyGroup">
                                                        <severity inherit="false">Error</severity>
                                                        <message inherit="false">-Registration Failure</message>
                                                    </applicationProperties>
                                                </item>
                                            </nestedSteps>
                                            <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                                        </item>
                                        <item guid="3e31f0b4-e7f1-4e07-a122-5dc2250e8c3c" action="else" useFieldsInCommand="false">
                                            <nestedSteps>
                                                <item guid="dcf65c89-6a8f-42a9-8581-19cf0e4e0ad4" action="eval" useFieldsInCommand="false">
                                                    <command>
                                                        <body>pct_good=100*(gm_dict[&apos;SIP Call Successes&apos;]/total_calls)</body>
                                                    </command>
                                                    <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                                                </item>
                                            </nestedSteps>
                                            <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                                        </item>
                                        <item guid="a80715e4-c379-41b4-8d98-b373f51020f0" action="eval" useFieldsInCommand="false">
                                            <command>
                                                <body>total_reg = gm_dict[&apos;SIP Registration Setup Count&apos;]+gm_dict[&apos;SIP Registration Failures&apos;]</body>
                                            </command>
                                            <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                                        </item>
                                        <item guid="61638b4c-a9fb-4cae-ae8a-cb0db247e73f" action="eval" useFieldsInCommand="false">
                                            <command>
                                                <body>setup_avg = int(gm_dict[&quot;SIP Average Call Setup (micro-sec)&quot;]/1000)</body>
                                            </command>
                                            <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                                        </item>
                                        <item guid="81e10379-ce8b-4e0b-9b2a-30a146687911" action="eval" useFieldsInCommand="false">
                                            <command>
                                                <body>setup_min = int(gm_dict[&quot;SIP Minimum Call Setup (micro-sec)&quot;]/1000)</body>
                                            </command>
                                            <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                                        </item>
                                        <item guid="cfe35b0e-1cff-4cb6-8130-737234b09b82" action="eval" useFieldsInCommand="false">
                                            <command>
                                                <body>setup_max = int(gm_dict[&quot;SIP Maximum Call Setup (micro-sec)&quot;]/1000)</body>
                                            </command>
                                            <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                                        </item>
                                        <item guid="eee30780-b8d7-4e52-9d47-5061b72dd566" action="message" useFieldsInCommand="false">
                                            <command>
                                                <body>Information:--Subscribers = [global_param_dic[&apos;global_overwrite_params&apos;][&apos;Sessions&apos;]]</body>
                                            </command>
                                            <applicationProperties type="com.fnfr.svt.execution.builtin.exec.MessagePropertyGroup">
                                                <severity inherit="false" defaultValue=""/>
                                                <message inherit="false">--Subscribers = [global_param_dic[&apos;global_overwrite_params&apos;][&apos;Sessions&apos;]]</message>
                                            </applicationProperties>
                                        </item>
