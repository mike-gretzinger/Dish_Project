                                            <command>
                                                <body>test_session_dic[&quot;tsGroups&quot;][0][&quot;testCases&quot;][0][&quot;parameters&quot;][&quot;UeCallLength&quot;]=param(&apos;CallLength&apos;)</body>
                                            </command>
