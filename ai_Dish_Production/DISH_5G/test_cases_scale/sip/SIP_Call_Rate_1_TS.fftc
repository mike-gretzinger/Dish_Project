                        <item guid="b0b59e6d-54da-412a-9136-f4182655ce06" action="Custom" session="s1">
                            <command>
                                <body>-requestMethod GET -dataType json -rawResponse true -url [tas_api_url]/runningTests/[running_test_id]/measurements/favorites</body>
