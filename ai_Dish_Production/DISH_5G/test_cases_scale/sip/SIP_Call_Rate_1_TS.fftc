                                                <body>test_session_dic[&quot;tsGroups&quot;][0][&quot;testCases&quot;][0][&quot;parameters&quot;].update(testserver_param_dic[&apos;ls_testServers&apos;][0][&quot;parameters&quot;])</body>
                                            </command>
