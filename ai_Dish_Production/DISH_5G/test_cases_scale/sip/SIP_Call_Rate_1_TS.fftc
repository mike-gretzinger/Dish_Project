                                        </item>
                                    </nestedSteps>
                                    <applicationProperties type="com.fnfr.svt.documents.EmptyPropertyGroup"/>
                                </item>
                                <item guid="471534d1-5a32-48f2-b0b3-ece13b0bcdf1" action="comment" useFieldsInCommand="false">
                                    <command>
                                        <body>Inserting Test Server Parameters</body>
                                    </command>
                                    <nestedSteps>
